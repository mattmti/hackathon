# ─────────────────────────────────────────────
# RabbitMQ
# ─────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_QUEUE=barcodes
RABBITMQ_DLQ=barcodes.dlq

# ─────────────────────────────────────────────
# MySQL
# ─────────────────────────────────────────────
MYSQL_USER=barcode
MYSQL_PASSWORD=barcode
MYSQL_DATABASE=barcode
MYSQL_ROOT_PASSWORD=root

# ─────────────────────────────────────────────
# S3 / LocalStack
# ─────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=barcodes

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
LOG_LEVEL=info
RETRY_MAX=3
RETRY_INITIAL_DELAY_MS=500
